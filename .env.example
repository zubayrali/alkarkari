# ── Locales (isolated builds — see docs/superpowers/specs/2026-07-02-i18n-design.md)
# One Obsidian vault per locale. Unsuffixed vars are accepted as a fallback for
# the default locale (en) only.
OBSIDIAN_VAULT_PATH_EN=
# OBSIDIAN_VAULT_PATH_FR=
# OBSIDIAN_VAULT_PATH_CN=

# Which locale `pnpm dev` / `pnpm build` / `pnpm stage` use (also set per-leg in CI).
SITE_LANGUAGE=en

# Vault folders/files to include per locale (saved by `pnpm generate -- --select`).
GENERATE_INCLUDE_EN=
# GENERATE_INCLUDE_FR=
# GENERATE_INCLUDE_CN=

# URL base path for GitHub Pages subpath hosting; CI sets /<repo>/<locale>.
# PAGES_BASE_PATH=
